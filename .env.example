# Contact form → CRM integration (src/routes/contact.ts)
# Copy to `.env` for local dev, and set the same values in the Vercel project.
# `.env` is gitignored — never commit real secrets.

# Shared HMAC secret. MUST be byte-for-byte identical to the CRM's
# PUBLIC_FORM_HMAC_SECRET, or every submission is rejected as an invalid signature.
PUBLIC_FORM_HMAC_SECRET=

# The CRM's public-form receiver endpoint.
CRM_FORM_ENDPOINT=https://your-crm-host/api/public-form

# The CRM's published-sermons feed (src/sermons-feed.ts). When set, /watch renders
# real, chaptered sermons published from the CRM (program = the chapters, with
# jump-to-timestamp links). Leave UNSET to fall back to the live YouTube latest
# video + the evergreen order-of-service — the page works fully either way.
CRM_SERMONS_ENDPOINT=https://your-crm-host/api/public/sermons
